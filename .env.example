# Porta interna que a API escuta (usada por `npm run dev`/`npm run start` fora do Docker)
PORT=4000
NODE_ENV=development

# Porta publicada no host pelo Docker Compose — em produção (VPS), é a porta que você abre
# no firewall/proxy. Por padrão tem o mesmo valor de PORT; o compose repassa esse valor para
# dentro do container como PORT, então normalmente basta manter os dois iguais.
API_PORT=4000

# Use "localhost" para rodar a API direto no host (`npm run dev`/`npm run start`) ou em
# desenvolvimento via Docker (o docker-compose.override.yml já corrige isso automaticamente).
# Em produção na VPS usando o Postgres do próprio docker-compose.yml (sem o override de dev),
# troque o host para "postgres" (nome do serviço). Se usar um Postgres externo/gerenciado,
# troque pela URL dele — nada mais no compose precisa mudar.
DATABASE_URL="postgresql://portus:portus@localhost:5432/portus_dev?schema=public"

JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="1d"

FRONTEND_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"

# Diretório onde evidências de RDO são salvas (nunca servido como estático — download é via rota autenticada)
UPLOADS_DIR="uploads"
MAX_UPLOAD_SIZE_MB=25
